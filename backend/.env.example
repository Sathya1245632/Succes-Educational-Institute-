# MongoDB connection string (from Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/success_db

# Port for the backend server
PORT=5000

# Secret for JWT signing
JWT_SECRET=your_super_secret_jwt_key_here

# Allowed frontend origin for CORS (separate multiple with commas if needed)
CORS_ORIGIN=https://your-success-frontend.vercel.app
